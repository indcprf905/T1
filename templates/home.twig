                </div>
            </div>
            
            <!-- Product 2: Leather Watch -->
            <div class="product-card" data-product-id="leather-watch">
                <div class="product-image">
                    <img src="{{ asset('assets/products/leather_watch.jpg') }}" alt="ساعة جلد أنيقة" loading="lazy">
                    <div class="product-overlay">
                        <button class="btn-wishlist" title="إضافة للمفضلة">♡</button>
                        <button class="btn-quick-view" title="عرض سريع">👁</button>
                    </div>
                    <span class="product-badge bestseller">الأكثر مبيعاً</span>
                </div>
                <div class="product-info">
