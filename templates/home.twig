                    <img src="{{ asset('assets/products/musk_candle.jpg') }}" alt="شمعة مسك طبيعية" loading="lazy">
                    <div class="product-overlay">
                        <button class="btn-wishlist" title="إضافة للمفضلة">♡</button>
                        <button class="btn-quick-view" title="عرض سريع">👁</button>
                    </div>
                    <span class="product-badge new">جديد</span>
                </div>
                <div class="product-info">
                    <h3 class="product-name">شمعة مسك طبيعية</h3>
                    <p class="product-description">شمعة عطرية طبيعية برائحة المسك الفاخرة</p>
                    <div class="product-rating">
                        <div class="stars">★★★★★</div>
