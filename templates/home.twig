{% extends "layouts/master.twig" %}

{% block title %}{{ store.name }} - {{ theme.settings.homepage.hero_title }}{% endblock %}

{% block content %}
<!-- Hero Banner Section -->
<section class="hero-banner" style="background-image: url('{{ asset('assets/hero.jpg') }}');">
    <div class="hero-overlay">
        <div class="container">
            <div class="hero-content">
                <h1 class="hero-title">
                    {{ theme.settings.homepage.hero_title ?: "مرحبًا بكم في متجر نور – وجهتكم المختارة لأجود العطور والإكسسوارات الفاخرة" }}
                </h1>
                <p class="hero-subtitle">
                    {{ theme.settings.homepage.hero_subtitle ?: "اكتشف مجموعة مختارة من أفخم العطور والإكسسوارات المميزة" }}
                </p>
                <a href="{{ theme.settings.homepage.hero_button_link ?: '/categories/all' }}" class="btn btn-primary hero-cta">
                    {{ theme.settings.homepage.hero_button_text ?: "تسوق الآن" }}
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Promotional Banners Carousel -->
<section class="promotional-banners">
    <div class="container">
        <div class="banners-carousel" id="bannersCarousel">
            <!-- Banner 1: Summer Offer -->
            <div class="banner-slide active">
                <div class="banner-content" style="background-image: url('{{ asset('assets/banners/summer_offer.jpg') }}');">
                    <div class="banner-overlay">
                        <div class="banner-text">
                            <h3 class="banner-title">{{ theme.settings.banners.banner1_title ?: "عرض الصيف - خصم حتى ٥٠٪" }}</h3>
                            <p class="banner-subtitle">{{ theme.settings.banners.banner1_subtitle ?: "تسوق الآن واستفد من العروض الموسمية" }}</p>
                            <a href="{{ theme.settings.banners.banner1_link ?: '/offers' }}" class="btn btn-outline">اكتشف العروض</a>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Banner 2: New Arrivals -->
            <div class="banner-slide">
                <div class="banner-content" style="background-image: url('{{ asset('assets/banners/new_arrivals.jpg') }}');">
                    <div class="banner-overlay">
                        <div class="banner-text">
                            <h3 class="banner-title">{{ theme.settings.banners.banner2_title ?: "وصل حديثًا" }}</h3>
                            <p class="banner-subtitle">{{ theme.settings.banners.banner2_subtitle ?: "اكتشف أحدث المنتجات المضافة" }}</p>
                            <a href="{{ theme.settings.banners.banner2_link ?: '/new' }}" class="btn btn-outline">شاهد الجديد</a>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Banner 3: Gift Cards -->
            <div class="banner-slide">
                <div class="banner-content" style="background-image: url('{{ asset('assets/banners/gift_card.jpg') }}');">
                    <div class="banner-overlay">
                        <div class="banner-text">
                            <h3 class="banner-title">{{ theme.settings.banners.banner3_title ?: "بطاقات الهدايا" }}</h3>
                            <p class="banner-subtitle">{{ theme.settings.banners.banner3_subtitle ?: "فاجئ من تحب بهدية رقمية فاخرة" }}</p>
                            <a href="{{ theme.settings.banners.banner3_link ?: '/gift-cards' }}" class="btn btn-outline">احصل على بطاقة</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Carousel Navigation -->
        <div class="carousel-navigation">
            <button class="carousel-prev" onclick="previousSlide()">‹</button>
            <div class="carousel-indicators">
                <span class="indicator active" onclick="currentSlide(1)"></span>
                <span class="indicator" onclick="currentSlide(2)"></span>
                <span class="indicator" onclick="currentSlide(3)"></span>
            </div>
            <button class="carousel-next" onclick="nextSlide()">›</button>
        </div>
    </div>
</section>

<!-- Featured Products Section -->
