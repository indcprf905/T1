{% extends "layouts/master.twig" %}

{% block title %}{{ landing.title ?: "عرض خاص" }} - {{ store.name }}{% endblock %}

{% block meta %}
    <meta name="description" content="{{ landing.description | striptags | slice(0, 160) }}">
    <meta property="og:title" content="{{ landing.title }}">
    <meta property="og:description" content="{{ landing.description | striptags | slice(0, 160) }}">
    <meta property="og:image" content="{{ landing.hero_image.url }}">
    <meta name="robots" content="index, follow">
{% endblock %}

{% block body_class %}landing-page{% endblock %}

{% block content %}
<!-- Hero Section -->
<section class="landing-hero">
    <div class="hero-background" style="background-image: url('{{ landing.hero_image.url ?: asset('assets/hero.jpg') }}');">
        <div class="hero-overlay"></div>
        <div class="container">
            <div class="hero-content">
                <div class="hero-badge">
                    <span class="badge-text">{{ landing.badge_text ?: "عرض محدود" }}</span>
                </div>
                
                <h1 class="hero-title">{{ landing.title ?: "عرض استثنائي لفترة محدودة" }}</h1>
                
                <div class="hero-subtitle">
                    {{ landing.subtitle ?: "اكتشف مجموعة مختارة من أفخم المنتجات بأسعار لا تُصدق" }}
                </div>
                
                {% if landing.discount_percentage %}
                    <div class="discount-highlight">
                        <span class="discount-text">خصم حتى</span>
                        <span class="discount-percentage">{{ landing.discount_percentage }}%</span>
                    </div>
                {% endif %}
                
                <!-- Countdown Timer -->
                {% if landing.end_date %}
                    <div class="countdown-timer" data-end-date="{{ landing.end_date }}">
                        <div class="countdown-label">ينتهي العرض خلال:</div>
                        <div class="countdown-display">
                            <div class="time-unit">
                                <span class="time-number" id="days">00</span>
                                <span class="time-label">يوم</span>
                            </div>
                            <div class="time-unit">
                                <span class="time-number" id="hours">00</span>
                                <span class="time-label">ساعة</span>
                            </div>
                            <div class="time-unit">
                                <span class="time-number" id="minutes">00</span>
                                <span class="time-label">دقيقة</span>
                            </div>
                            <div class="time-unit">
                                <span class="time-number" id="seconds">00</span>
                                <span class="time-label">ثانية</span>
                            </div>
                        </div>
                    </div>
                {% endif %}
                
                <div class="hero-actions">
                    <a href="#featured-products" class="btn btn-primary btn-lg hero-cta">
                        {{ landing.cta_text ?: "تسوق الآن" }}
                    </a>
                    <a href="#offer-details" class="btn btn-outline btn-lg">
                        تفاصيل العرض
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Trust Indicators -->
<section class="trust-indicators">
    <div class="container">
        <div class="indicators-grid">
            <div class="indicator-item">
                <div class="indicator-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 12l2 2 4-4"></path>
                        <path d="M21 12c-1 0-3-1-3-3s2-3 3-3 3 1 3 3-2 3-3 3"></path>
                        <path d="M3 12c1 0 3-1 3-3s-2-3-3-3-3 1-3 3 2 3 3 3"></path>
                    </svg>
                </div>
                <div class="indicator-text">
                    <h4>جودة مضمونة</h4>
                    <p>منتجات أصلية 100%</p>
                </div>
            </div>
            
            <div class="indicator-item">
                <div class="indicator-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="1" y="3" width="15" height="13"></rect>
                        <polygon points="16,8 20,8 23,11 23,16 20,16 20,13 16,13"></polygon>
                        <circle cx="5.5" cy="18.5" r="2.5"></circle>
                        <circle cx="18.5" cy="18.5" r="2.5"></circle>
                    </svg>
                </div>
                <div class="indicator-text">
                    <h4>شحن سريع</h4>
                    <p>توصيل خلال 24 ساعة</p>
                </div>
            </div>
            
            <div class="indicator-item">
                <div class="indicator-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2 2z"></path>
                        <path d="M8 1v4"></path>
                        <path d="M16 1v4"></path>
                    </svg>
                </div>
                <div class="indicator-text">
                    <h4>إرجاع مجاني</h4>
                    <p>خلال 7 أيام</p>
                </div>
            </div>
            
            <div class="indicator-item">
                <div class="indicator-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                        <path d="M7 11V7a5 5 0 0110 0v4"></path>
                    </svg>
                </div>
                <div class="indicator-text">
                    <h4>دفع آمن</h4>
                    <p>معاملات مشفرة</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Products -->
<section class="featured-products" id="featured-products">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">{{ landing.products_title ?: "منتجات العرض المميزة" }}</h2>
            <p class="section-subtitle">{{ landing.products_subtitle ?: "مجموعة مختارة من أفضل منتجاتنا بأسعار مخفضة" }}</p>
        </div>
        
        <div class="products-showcase">
            {% if landing.featured_products %}
                {% for product in landing.featured_products %}
                    <div class="showcase-product" data-product-id="{{ product.id }}">
                        <div class="product-image">
                            <img src="{{ product.image.url }}" alt="{{ product.name }}" loading="lazy">
                            
                            <!-- Discount Badge -->
                            {% if product.sale_price %}
                                <div class="discount-badge">
                                    <span class="discount-percent">-{{ ((product.regular_price - product.sale_price) / product.regular_price * 100) | round }}%</span>
                                    <span class="save-amount">وفر {{ product.regular_price - product.sale_price }} ريال</span>
                                </div>
                            {% endif %}
                            
                            <!-- Limited Stock Indicator -->
                            {% if product.stock < 10 %}
                                <div class="stock-warning">
                                    <span>متبقي {{ product.stock }} قطع فقط!</span>
                                </div>
                            {% endif %}
                        </div>
                        
                        <div class="product-details">
                            <h3 class="product-name">{{ product.name }}</h3>
                            <p class="product-description">{{ product.summary | slice(0, 120) }}...</p>
                            
                            <div class="product-rating">
                                <div class="stars">
                                    {% for i in 1..5 %}
                                        <span class="star {{ i <= product.rating.average ? 'filled' : '' }}">★</span>
                                    {% endfor %}
                                </div>
                                <span class="rating-count">({{ product.rating.count }} تقييم)</span>
                            </div>
                            
                            <div class="price-section">
                                {% if product.sale_price %}
                                    <div class="price-row">
                                        <span class="current-price">{{ product.sale_price }} ريال</span>
                                        <span class="original-price">{{ product.regular_price }} ريال</span>
                                    </div>
                                    <div class="savings-text">
                                        توفر {{ product.regular_price - product.sale_price }} ريال
                                    </div>
                                {% else %}
                                    <span class="current-price">{{ product.price }} ريال</span>
                                {% endif %}
                            </div>
                            
                            <!-- Product Features -->
                            {% if product.key_features %}
                                <ul class="product-features">
                                    {% for feature in product.key_features | slice(0, 3) %}
                                        <li>{{ feature }}</li>
                                    {% endfor %}
                                </ul>
                            {% endif %}
                            
